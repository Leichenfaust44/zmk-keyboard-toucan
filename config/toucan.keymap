 *
 * SPDX-License-Identifier: MIT
 *
 * Gallium v2 layout (customized) with home row mods
 * Swiss German (DE-CH) keyboard layout
 * Toucan Keyboard вЂ” 5-col layout (identical key positions to Piantor Pro BT)
 *
 * Layer order:
 *   0 = Base (default)
 *   1 = Sym
 *   2 = FN      в†ђ also activated momentarily by trackpad touch (touch_processor в†’ mo 2)
 *   3 = Nav    в†ђ trackpad acts as scroll wheel on this layer
 *
 * ============================================================
 * Base (Layer 0): Default layer
 * ============================================================
 * Layout: Gallium v1, Columnar Staggered Version
 *
 * Top row: B L D C V | J F O U ?/!
 * Home row: N R T S G | Y H A E I
 * Bot row: X Q M W Z | K P ,/; ./: -/_
 *
 * Top row hold-taps (mt):
 * ?=!
 *
 * Bot row hold-taps (mt):
 * ,=; .=: -=_
 *
 * Home row mods (cross-hand activation only):
 * Left: N=Super(slow)  R=Alt(slow)  T=Ctrl(slow)  S=Shift(fast)
 * Right: H=Shift(fast)  A=Ctrl(slow)  E=Alt(slow)  I=Super(slow)
 *
 * Thumbs:
 * ESC | Space(hold=Nav/3) | MagicKey(hold=FN/2) | SmartShift | BSPC | Sym(tap=num_word,hold=layer)
 *
 * ============================================================
 * Sym (Layer 1): Numbers and symbols
 * ============================================================
 * Activated by: tap Sym thumb (num_word), hold Sym thumb (momentary)
 * num_word auto-exits on non-number/symbol keys
 *
 * Top row: вЂ” 7 8 9 вЂ” | [ ] < > |
 * Home row: 0 4 5 6 вЂ” | { } ^ ` ~
 * Bot row: . 1 2 3 вЂ” | ` Вґ В§ В° вЂ”
 *
 * Thumbs: to(0) | SPACE | вЂ” | to(0) | BSPC | num_word
 *
 * ============================================================
 * FN (Layer 2): Function keys and mouse
 * ============================================================
 * Activated by: hold MagicKey thumb OR trackpad touch on layer 0
 *
 * Top row: F10 F7 F8 F9 вЂ” | вЂ” вЂ” вЂ” вЂ” вЂ”
 * Home row: F11 F4 F5 F6 вЂ” | вЂ” RSft RCtl RAlt RGui
 * Bot row: F12 F1 F2 F3 вЂ” | вЂ” вЂ” вЂ” вЂ” вЂ”
 *
 * Thumbs: вЂ” | вЂ” | вЂ” | LClick | RClick | MClick
 *
 * ============================================================
 * Nav (Layer 3): Navigation and system controls
 * ============================================================
 * Activated by: hold Space thumb
 * Trackpad acts as scroll wheel on this layer.
 *
 * Top row: BtClrAll** Next VolUp RGB_OFF StudioUnlk | PgUp Home Up End BtClr**
 * Home row: вЂ” Prev VolDn вЂ” вЂ” | PgDn Left Down Right Reset**
 * Bot row: Boot** Play Mute MicMute вЂ” | CapsL вЂ” PrtSc вЂ” Boot**
 *
 * MicMute = LGui+RAlt+K shortcut
 * CapsL = Caps Lock (manual toggle)
 * ** = tap-dance safety: single tap = nothing, double-tap = action
 *
 * Thumbs: BT_PRV | BT(0) | BT_NXT | вЂ” | вЂ” | вЂ”
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/rgb.h>
#include <dt-bindings/zmk/outputs.h>
#define ZMK_POINTING_DEFAULT_SCRL_VAL 20
#include <dt-bindings/zmk/pointing.h>
#include <behaviors/num_word.dtsi>
#include "keys_de_swiss.h"

// urob's helper macros for ZMK behaviors
#include "zmk-helpers/helper.h"

&num_word {
    continue-list = <BSPC DEL DOT PLUS MINUS ASTRK FSLH EQUAL SPACE>;
};

&sl {
    release-after-ms = <5000>;
    ignore-modifiers;
};

&sk {
    release-after-ms = <5000>;
    quick-release;
};

&mt {
    tapping-term-ms = <300>;
    quick-tap-ms = <0>;
    require-prior-idle-ms = <175>;
    flavor = "tap-preferred";
    hold-trigger-on-release;
};

/ {
    chosen {
        zmk,physical-layout = &five_col_layout;
    };
};

/ {
    behaviors {
        #include "toucan_behaviors.dtsi"
    };

    #include "toucan_combos.dtsi"

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "Base";
            // Gallium (customized: Xв†”Q) with home row mods
            // Top row hold-taps: ?=!
            // Bot row hold-taps: ,=; .=: -=_
            // Home row mods вЂ” Left: N=Super(slow) R=Alt(slow) T=Ctrl(slow) S=Shift(fast)
            //               вЂ” Right: H=Shift(fast) A=Ctrl(slow) E=Alt(slow) I=Super(slow)
            // -----------------------------------------------------------------------
            // |  B  |  L  |  D  |  C  |  V  |   |  J  |  F  |  O  |  U  | ?/! |
            // |N/Guв†“|R/Alв†“|T/Ctв†“|S/Sfв†‘|  G  |   |  Y  |H/Sfв†‘|A/Ctв†“|E/Alв†“|I/Guв†“|
            // |  X  |  Q  |  M  |  W  |  Z  |   |  K  |  P  | ,/; | ./: | -/_ |
            //       | ESC | Space(Nav) | MagicKey(FN) | SmartShift | BSPC | Sym |
            // в†‘ = fast (hml_shift / hmr_shift)
            // в†“ = slow (hml_slow  / hmr_slow)

            bindings = <
                &kp B                    &kp L                &kp D                     &kp C                    &kp V      &kp J      &kp F                    &kp O                     &kp U                &mt DE_EXCL DE_QMARK
                &hml_slow LEFT_GUI N     &hml_slow LEFT_ALT R &hml_slow LEFT_CONTROL T  &hml_shift LEFT_SHIFT S  &kp G      &kp DE_Y   &hmr_shift RIGHT_SHIFT H &hmr_slow RIGHT_CONTROL A &hmr_slow RIGHT_ALT E &hmr_slow RIGHT_GUI I
                &kp X                    &kp Q                &kp M                     &kp W                    &kp DE_Z   &kp K      &kp P                    &mt DE_SEMI DE_COMMA      &mt DE_COLON DE_DOT  &mt DE_UNDER DE_MINUS
                                         &kp ESCAPE           &space_nav 3 DE_SPACE     &magic_key 2 0           &shift_morph LSHIFT 0  &bspc_del  &glyph_tap 1 1
            >;
        };

        num_sym_layer {
            display-name = "Sym";
            // Numbers and symbols. Activated via Glyph thumb (num_word tap or momentary hold).
            // num_word auto-exits on non-number/symbol keys.
            // Home row mods вЂ” Left: 0=Super(slow) 4=Alt(slow) 5=Ctrl(slow) 6=Shift(fast)
            //               вЂ” Right: }=Shift(fast) ^=Ctrl(slow) `=Alt(slow) ~=Super(slow)
            // -----------------------------------------------------------------------
            // |  вЂ”  |  7  |  8  |  9  |  вЂ”  |   |  [  |  ]  |  <  |  >  |  |  |
            // |0/Guв†“|4/Alв†“|5/Ctв†“|6/Sfв†‘|  вЂ”  |   |  {  |}/ в†‘ |^/Ctв†“|`/Alв†“|~/Guв†“|
            // |  .  |  1  |  2  |  3  |  вЂ”  |   |  `  |  Вґ  |  В§  |  В°  |  вЂ”  |
            //       | to(0) | SPACE | вЂ” | to(0) | BSPC | num_word |

            bindings = <
                &none                        &kp DE_N7                &kp DE_N8                    &kp DE_N9                    &none      &kp DE_LBKT   &kp DE_RBKT                      &kp DE_LT                         &kp DE_GT                    &kp DE_PIPE
                &hml_slow LEFT_GUI DE_N0     &hml_slow LEFT_ALT DE_N4 &hml_slow LEFT_CONTROL DE_N5 &hml_shift LEFT_SHIFT DE_N6  &none      &kp DE_LBRC   &hmr_shift RIGHT_SHIFT DE_RBRC   &hmr_slow RIGHT_CONTROL DE_CARET  &hmr_slow RIGHT_ALT DE_GRAVE &hmr_slow RIGHT_GUI DE_TILDE
                &kp DE_DOT                   &kp DE_N1                &kp DE_N2                    &kp DE_N3                    &none      &kp DE_GRAVE  &kp DE_ACUTE                     &kp DE_SECT                       &kp DE_DEG                   &none
                                             &to 0                    &kp DE_SPACE                 &none                        &to 0      &bspc_del     &num_word 1
            >;
        };

        fn_layer {
            display-name = "FN";
            // Function keys and mouse. Activated by holding MagicKey thumb (mo 2)
            // OR trackpad touch (touch_processor в†’ mo 2).
            // Right side: raw modifiers on home row.
            // Mouse buttons on thumb cluster (LClick / RClick / MClick) вЂ” Toucan-spezifisch.
            // -----------------------------------------------------------------------
            // | F10 | F7  | F8  | F9  |  вЂ”  |   |  вЂ”  |  вЂ”  |  вЂ”  |  вЂ”  |  вЂ”  |
            // | F11 | F4  | F5  | F6  |  вЂ”  |   |  вЂ”  |RSft |RCtl |RAlt |RGui |
            // | F12 | F1  | F2  | F3  |  вЂ”  |   |  вЂ”  |  вЂ”  |  вЂ”  |  вЂ”  |  вЂ”  |
            //       |  вЂ”  |  вЂ”  |  вЂ”  | LClick | RClick | MClick |

            bindings = <
                &kp F10  &kp F7  &kp F8  &kp F9  &none   &none  &none              &none                 &none          &none
                &kp F11  &kp F4  &kp F5  &kp F6  &none   &none  &kp RIGHT_SHIFT    &kp RIGHT_CONTROL     &kp RIGHT_ALT  &kp RIGHT_GUI
                &kp F12  &kp F1  &kp F2  &kp F3  &none   &none  &none              &none                 &none          &none
                         &none   &none   &none   &mkp LCLK  &mkp RCLK  &mkp MCLK
            >;
        };

        nav_sys_layer {
            display-name = "Nav";
            // Navigation and system controls. Activated by holding Space thumb (mo 3).
            // Left: media, BT, RGB controls. Right: navigation keys.
            // Trackpad acts as scroll wheel on this layer (toucan.dtsi scroller в†’ layers = <3>).
            // MicMute = LGui+RAlt+K shortcut
            // CapsL = Caps Lock
            // ** = tap-dance safety: single tap = nothing, double-tap = action
            // -----------------------------------------------------------------------
            // |BtClrAll**| Next | VolUp |RGB_OFF|StudioUnlk|  |PgUp | Home | Up   | End  |BtClr** |
            // |    вЂ”     | Prev | VolDn |   вЂ”   |    вЂ”     |  |PgDn | Left | Down | Rght |Reset** |
            // |  Boot**  | Play | Mute  |MicMute|    вЂ”     |  |CapsL|  вЂ”   |PrtSc |  вЂ”   |Boot**  |
            //            | BT_PRV | BT(0) | BT_NXT |   |  вЂ”  |  вЂ”  |  вЂ”  |

            bindings = <
                &td_bt_clr_all  &kp C_NEXT  &kp C_VOL_UP  &rgb_ug RGB_OFF  &studio_unlock   &kp PG_UP     &kp HOME  &kp UP    &kp END    &td_bt_clr
                &none           &kp C_PREV  &kp C_VOL_DN  &none            &none            &kp PG_DN     &kp LEFT  &kp DOWN  &kp RIGHT  &td_reset
                &td_boot        &kp C_PP    &kp C_MUTE    &kp LG(RA(K))   &none            &kp CAPSLOCK  &none     &kp PSCRN &none      &td_boot
                                &bt BT_PRV  &bt BT_SEL 0  &bt BT_NXT      &none            &none         &none
            >;
        };

    };
};
