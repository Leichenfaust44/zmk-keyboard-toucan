// =============================================================================
// Custom Behaviors for Toucan Keyboard
// =============================================================================
// Layer reference:
//   0 = Gallium (default)   1 = Glyph   2 = Helm   3 = Bridge
//
// Timing Summary:
//   Home row mods — Shift (hml_shift/hmr_shift):        200ms tap, 175ms quick-tap, 120ms prior-idle
//   Home row mods — Ctrl/Alt/Super (hml_slow/hmr_slow): 400ms tap, 175ms quick-tap, 400ms prior-idle
//   Space/Nav (space_nav):         220ms tap, 175ms quick-tap, 175ms prior-idle
//   Magic Key (magic_key):         200ms tap, 0ms quick-tap (tap-preferred)
//   Glyph (glyph_tap):             240ms tap, 0ms quick-tap (balanced)
//   Tap-dances (safety wrappers):  300ms double-tap window
//   Combos:                        50ms timeout, 175ms prior-idle
//
// =============================================================================


// -----------------------------------------------------------------------------
// HOME ROW MODS — SHIFT (aggressive)
// -----------------------------------------------------------------------------
// Faster activation for Shift — used constantly during normal typing.
// Timing: 200ms tapping term, 175ms quick-tap, 120ms prior-idle guard.

// Left-hand Shift HRM
hml_shift: homerow_mods_left_shift {
    compatible = "zmk,behavior-hold-tap";
    #binding-cells = <2>;
    flavor = "balanced";
    require-prior-idle-ms = <120>;
    tapping-term-ms = <200>;
    quick-tap-ms = <175>;
    bindings = <&kp>, <&kp>;
    hold-trigger-key-positions = <5 6 7 8 9 15 16 17 18 19 25 26 27 28 29 33 34 35>;
    hold-trigger-on-release;
};

// Right-hand Shift HRM
hmr_shift: homerow_mods_right_shift {
    compatible = "zmk,behavior-hold-tap";
    #binding-cells = <2>;
    flavor = "balanced";
    require-prior-idle-ms = <120>;
    tapping-term-ms = <200>;
    quick-tap-ms = <175>;
    bindings = <&kp>, <&kp>;
    hold-trigger-key-positions = <0 1 2 3 4 10 11 12 13 14 20 21 22 23 24 30 31 32>;
    hold-trigger-on-release;
};


// -----------------------------------------------------------------------------
// HOME ROW MODS — CTRL / ALT / SUPER (conservative)
// -----------------------------------------------------------------------------
// Slow, deliberate activation — rarely used, always intentional.
// Long tapping-term and prior-idle prevent accidental triggering.
// Timing: 400ms tapping term, 175ms quick-tap, 400ms prior-idle guard.

// Left-hand Ctrl/Alt/Super HRM
hml_slow: homerow_mods_left_slow {
    compatible = "zmk,behavior-hold-tap";
    #binding-cells = <2>;
    flavor = "balanced";
    require-prior-idle-ms = <400>;
    tapping-term-ms = <400>;
    quick-tap-ms = <175>;
    bindings = <&kp>, <&kp>;
    hold-trigger-key-positions = <5 6 7 8 9 15 16 17 18 19 25 26 27 28 29 33 34 35>;
    hold-trigger-on-release;
};

// Right-hand Ctrl/Alt/Super HRM
hmr_slow: homerow_mods_right_slow {
    compatible = "zmk,behavior-hold-tap";
    #binding-cells = <2>;
    flavor = "balanced";
    require-prior-idle-ms = <400>;
    tapping-term-ms = <400>;
    quick-tap-ms = <175>;
    bindings = <&kp>, <&kp>;
    hold-trigger-key-positions = <0 1 2 3 4 10 11 12 13 14 20 21 22 23 24 30 31 32>;
    hold-trigger-on-release;
};


// -----------------------------------------------------------------------------
// UMLAUT MACROS
// -----------------------------------------------------------------------------
// German umlauts via dead key composition: backspace + DE_UMLAUT + vowel.
// Lowercase: release shift → BSPC → dead umlaut → vowel
// Uppercase: release shift → BSPC → CAPSLOCK → dead umlaut → vowel → CAPSLOCK
// Triggered by magic_key adaptive behavior after typing a/A/o/O/u/U.
// -----------------------------------------------------------------------------

// ä
uml_a: umlaut_a {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings
        = <&macro_tap &kp BACKSPACE>
        , <&macro_tap &kp DE_UMLAUT>
        , <&macro_tap &kp A>
        ;
};

// Ä
uml_a_upper: umlaut_a_upper {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings
        = <&macro_release &kp LSHIFT &kp RSHIFT>
        , <&macro_tap &kp BACKSPACE>
        , <&macro_tap &kp CAPSLOCK>
        , <&macro_tap &kp DE_UMLAUT>
        , <&macro_tap &kp A>
        , <&macro_tap &kp CAPSLOCK>
        ;
};

// ö
uml_o: umlaut_o {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings
        = <&macro_tap &kp BACKSPACE>
        , <&macro_tap &kp DE_UMLAUT>
        , <&macro_tap &kp O>
        ;
};

// Ö
uml_o_upper: umlaut_o_upper {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings
        = <&macro_release &kp LSHIFT &kp RSHIFT>
        , <&macro_tap &kp BACKSPACE>
        , <&macro_tap &kp CAPSLOCK>
        , <&macro_tap &kp DE_UMLAUT>
        , <&macro_tap &kp O>
        , <&macro_tap &kp CAPSLOCK>
        ;
};

// ü
uml_u: umlaut_u {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings
        = <&macro_tap &kp BACKSPACE>
        , <&macro_tap &kp DE_UMLAUT>
        , <&macro_tap &kp U>
        ;
};

// Ü
uml_u_upper: umlaut_u_upper {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings
        = <&macro_release &kp LSHIFT &kp RSHIFT>
        , <&macro_tap &kp BACKSPACE>
        , <&macro_tap &kp CAPSLOCK>
        , <&macro_tap &kp DE_UMLAUT>
        , <&macro_tap &kp U>
        , <&macro_tap &kp CAPSLOCK>
        ;
};


// -----------------------------------------------------------------------------
// SPECIAL CHARACTER MACROS
// -----------------------------------------------------------------------------

// Parentheses with cursor in between: ()←
paren_pair: paren_pair_macro {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings
        = <&macro_tap &kp DE_LEFT_PARENTHESIS>
        , <&macro_tap &kp DE_RIGHT_PARENTHESIS>
        , <&macro_tap &kp LEFT>
        ;
};

// Double quotes with cursor in between: ""←
quote_pair: quote_pair_macro {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings
        = <&macro_tap &kp DE_DQT>
        , <&macro_tap &kp DE_DQT>
        , <&macro_tap &kp LEFT>
        ;
};


// -----------------------------------------------------------------------------
// MAGIC KEY SYSTEM — Piantor DE-optimised bigram set
// -----------------------------------------------------------------------------
// Adaptive substitutions:
//   E→U  «eu»: SFB Ringfinger rechts x2, «heute/neu/Euro»
//   I→E  «ie»: rückwärts Roll Kleinfinger→Ringfinger rechts, «die/wie/nie»
//   L→D  «ld»: rückwärts Roll gleiche Reihe links, «Wald/Geld/wild»
//   N→D  «nd»: rückwärts home→top links, «und/Kind/Hand»
//   P→F  «pf»: SFB Zeigefinger rechts x2, «Pferd/Kopf/Pfanne»
//   Q→U  «qu»: Q kommt praktisch nie ohne U vor
//   -→>  arrow: ->
//   Umlauts (1s): a→ä  A→Ä  o→ö  O→Ö  u→ü  U→Ü
//   Default: key_repeat
//
// Timeout: Umlauts 1000ms, all others 5000ms.
// -----------------------------------------------------------------------------

magic_key_tap: magic_key_tap {
    compatible = "zmk,behavior-adaptive-key";
    #binding-cells = <0>;
    bindings = <&key_repeat>;

    // a → ä
    repeat_a {
        trigger-keys = <A>;
        bindings = <&uml_a>;
        max-prior-idle-ms = <1000>;
        strict-modifiers;
    };

    // A → Ä
    repeat_a_upper {
        trigger-keys = <LS(A)>;
        bindings = <&uml_a_upper>;
        max-prior-idle-ms = <1000>;
        strict-modifiers;
    };

    // E → U (bigram «eu»)
    repeat_e {
        trigger-keys = <E>;
        bindings = <&kp U>;
        max-prior-idle-ms = <5000>;
        strict-modifiers;
    };

    // I → E (bigram «ie»)
    repeat_i {
        trigger-keys = <I>;
        bindings = <&kp E>;
        max-prior-idle-ms = <5000>;
        strict-modifiers;
    };

    // L → D (bigram «ld»)
    repeat_l {
        trigger-keys = <L>;
        bindings = <&kp D>;
        max-prior-idle-ms = <5000>;
        strict-modifiers;
    };

    // N → D (bigram «nd»)
    repeat_n {
        trigger-keys = <N>;
        bindings = <&kp D>;
        max-prior-idle-ms = <5000>;
        strict-modifiers;
    };

    // o → ö
    repeat_o {
        trigger-keys = <O>;
        bindings = <&uml_o>;
        max-prior-idle-ms = <1000>;
        strict-modifiers;
    };

    // O → Ö
    repeat_o_upper {
        trigger-keys = <LS(O)>;
        bindings = <&uml_o_upper>;
        max-prior-idle-ms = <1000>;
        strict-modifiers;
    };

    // P → F (bigram «pf»)
    repeat_p {
        trigger-keys = <P>;
        bindings = <&kp F>;
        max-prior-idle-ms = <5000>;
        strict-modifiers;
    };

    // Q → U (bigram «qu»)
    repeat_q {
        trigger-keys = <Q>;
        bindings = <&kp U>;
        max-prior-idle-ms = <5000>;
        strict-modifiers;
    };

    // u → ü
    repeat_u {
        trigger-keys = <U>;
        bindings = <&uml_u>;
        max-prior-idle-ms = <1000>;
        strict-modifiers;
    };

    // U → Ü
    repeat_u_upper {
        trigger-keys = <LS(U)>;
        bindings = <&uml_u_upper>;
        max-prior-idle-ms = <1000>;
        strict-modifiers;
    };

    // - → > (arrow: ->)
    repeat_minus {
        trigger-keys = <DE_MINUS>;
        bindings = <&kp DE_GT>;
        max-prior-idle-ms = <5000>;
        strict-modifiers;
    };
};

// Hold = momentary layer (&mo), Tap = magic_key_tap.
// Timing: 200ms tapping term (tap-preferred), 0ms quick-tap.
magic_key: magic_key {
    compatible = "zmk,behavior-hold-tap";
    #binding-cells = <2>;
    flavor = "tap-preferred";
    tapping-term-ms = <200>;
    quick-tap-ms = <0>;
    require-prior-idle-ms = <175>;
    bindings = <&mo>, <&magic_key_tap>;
};


// -----------------------------------------------------------------------------
// TAP-DANCE SAFETY WRAPPERS (dangerous / destructive actions)
// Single tap = nothing. Double tap = action.
// -----------------------------------------------------------------------------

td_bt_clr_all: tap_dance_bt_clear_all {
    compatible = "zmk,behavior-tap-dance";
    #binding-cells = <0>;
    tapping-term-ms = <300>;
    bindings = <&none>, <&bt BT_CLR_ALL>;
};

td_bt_clr: tap_dance_bt_clear {
    compatible = "zmk,behavior-tap-dance";
    #binding-cells = <0>;
    tapping-term-ms = <300>;
    bindings = <&none>, <&bt BT_CLR>;
};

td_reset: tap_dance_reset {
    compatible = "zmk,behavior-tap-dance";
    #binding-cells = <0>;
    tapping-term-ms = <300>;
    bindings = <&none>, <&sys_reset>;
};

td_boot: tap_dance_bootloader {
    compatible = "zmk,behavior-tap-dance";
    #binding-cells = <0>;
    tapping-term-ms = <300>;
    bindings = <&none>, <&bootloader>;
};


// -----------------------------------------------------------------------------
// SPACE / NAV THUMB
// -----------------------------------------------------------------------------
// Hold = momentary Bridge layer, Tap = space.
// Excludes dangerous corner positions (0,9,10,19,20,29) from hold-triggers.
// Timing: 220ms tapping term (tap-preferred), 175ms quick-tap, 175ms prior-idle.

space_nav: space_nav_layer {
    compatible = "zmk,behavior-hold-tap";
    #binding-cells = <2>;
    flavor = "tap-preferred";
    require-prior-idle-ms = <175>;
    tapping-term-ms = <220>;
    quick-tap-ms = <175>;
    bindings = <&mo>, <&kp>;
    hold-trigger-key-positions = <1 2 3 4 5 6 7 8 11 12 13 14 15 16 17 18 21 22 23 24 25 26 27 28 30 31 32 33 34 35>;
    hold-trigger-on-release;
};


// -----------------------------------------------------------------------------
// GLYPH THUMB KEY
// -----------------------------------------------------------------------------
// Hold = momentary Glyph layer, Tap = num_word (auto-exits on non-number key).
// Timing: 240ms tapping term (balanced), 0ms quick-tap.

glyph_tap: glyph_toggle_hold {
    compatible = "zmk,behavior-hold-tap";
    #binding-cells = <2>;
    flavor = "balanced";
    tapping-term-ms = <240>;
    quick-tap-ms = <0>;
    require-prior-idle-ms = <175>;
    bindings = <&mo>, <&num_word>;
};


// -----------------------------------------------------------------------------
// BSPC / DEL MORPH
// -----------------------------------------------------------------------------
// Tap = Backspace. Shift+Tap = Delete.

bspc_del: backspace_delete {
    compatible = "zmk,behavior-mod-morph";
    #binding-cells = <0>;
    bindings = <&kp BSPC>, <&kp DEL>;
    mods = <(MOD_LSFT|MOD_RSFT)>;
};


// -----------------------------------------------------------------------------
// SMART SHIFT
// -----------------------------------------------------------------------------
// Three-in-one shift key:
//   Tap        = Sticky Shift (capitalises next keypress only)
//   Hold       = Regular Shift
//   Double-tap = Caps Word (capitalises until word boundary)
//
// Implementation: mod-morph so Shift+tap → caps_word with no tap-dance delay.

// Tap = sticky-shift; already shifted → caps_word.
smart_shift: smart_shift {
    compatible = "zmk,behavior-mod-morph";
    #binding-cells = <0>;
    bindings = <&sk LSHIFT>, <&caps_word>;
    mods = <(MOD_LSFT|MOD_RSFT)>;
};

// Hold = regular shift, Tap = smart_shift.
// Timing: 200ms tapping term (tap-preferred), 175ms quick-tap.
shift_morph: shift_morph {
    compatible = "zmk,behavior-hold-tap";
    #binding-cells = <2>;
    flavor = "tap-preferred";
    tapping-term-ms = <200>;
    quick-tap-ms = <175>;
    bindings = <&kp>, <&smart_shift>;
};
